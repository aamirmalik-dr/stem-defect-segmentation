data/*
!data/README.md
!data/sample/
data/sample/*
!data/sample/*.npz
!data/real/
data/real/*
!data/real/README.md

# Notebook execution noise
.ipynb_checkpoints/

# Large checkpoints stay out; the small committed models stay in.
checkpoints/
*.ckpt

